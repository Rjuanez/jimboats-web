POSTGRES_USER="jimboats"
POSTGRES_PASSWORD="jimboats"
POSTGRES_DB="jimboats"

# Local Docker development points at the internal db service.
# PostgreSQL is not exposed to the host, so it cannot clash with other projects.
DATABASE_URL="postgresql://jimboats:jimboats@db:5432/jimboats?schema=public"

# Host-only development is not the default path. If needed, override DATABASE_URL
# with a project-specific host port instead of using localhost:5432 blindly.

# Production VPS values live in /srv/jimboats/web/.env.production and are not committed.
# In production DATABASE_URL must point at the internal Docker Compose service:
# DATABASE_URL="postgresql://jimboats:change-me@db:5432/jimboats?schema=public"
APP_DOMAIN="jimboats.example.com"
CADDY_EMAIL="admin@example.com"
PUBLIC_SITE_URL="https://jimboats.example.com"
ADMIN_BASIC_AUTH_USER="jimboats"
# Keep bcrypt hashes in single quotes in .env.production because they contain $.
ADMIN_BASIC_AUTH_HASH='$2a$14$syYeKcQVJj0QgxEzEbRb4elCstuDDuUSEr8f.qrKYhgbCfmSWsBAy'
IMAGE_REPOSITORY="ghcr.io/owner/repository"
IMAGE_TAG="local"
APP_IMAGE="ghcr.io/owner/repository:local"

MEDIA_ROOT="/var/lib/jimboats/media"
MEDIA_PUBLIC_BASE_URL="/media"
MEDIA_WORKER_POLL_INTERVAL_MS="2000"

# Notifications use console mode by default in local development.
# Set NOTIFICATION_PROVIDER_MODE="external" to send real messages through
# Resend and Prelude.
NOTIFICATION_PROVIDER_MODE="console"
NOTIFICATION_WORKER_POLL_INTERVAL_MS="2000"

RESEND_API_KEY=""
RESEND_BASE_URL="https://api.resend.com"
RESEND_FROM="JimBoats <bookings@jimboatscharter.com>"
RESEND_REPLY_TO="info@jimboatscharter.com"

PRELUDE_API_KEY=""
PRELUDE_BASE_URL="https://api.prelude.so"
PRELUDE_CALLBACK_URL=""
PRELUDE_FROM=""

# Stripe Checkout charges only the fixed online deposit. Keep secrets outside
# git in local .env / production .env.production.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Statsig client analytics is disabled by default. Enable only after deciding
# the public analytics consent behavior for production.
NEXT_PUBLIC_STATSIG_ANALYTICS_ENABLED="false"
NEXT_PUBLIC_STATSIG_CLIENT_KEY=""

# Google Calendar sync is disabled by default. When enabled, share the target
# calendar with GOOGLE_CLIENT_EMAIL using permissions to make changes to events.
GOOGLE_CALENDAR_ENABLED="false"
GOOGLE_CALENDAR_ID=""
GOOGLE_CLIENT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
