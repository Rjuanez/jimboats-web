generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ExperienceStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum ExperienceMediaStatus {
  MISSING
  PROCESSING
  READY
  FAILED
}

enum SlotPolicyMode {
  FIXED_SLOTS
  ANY_AVAILABLE
  MANUAL_APPROVAL
}

enum ExtraStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum LocalizedContentStatus {
  DRAFT
  NEEDS_TRANSLATION
  NEEDS_REVIEW
  OUTDATED
  READY
  PUBLISHED
  ARCHIVED
}

enum IndexingPolicy {
  INDEX
  NOINDEX
}

enum MediaAssetStatus {
  PROCESSING
  READY
  FAILED
}

enum MediaAssetCollection {
  EXPERIENCES
  EXTRAS
  GALLERY
  PAGES
}

enum MediaProcessingJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum HomeGalleryLayout {
  BALANCED
  LANDSCAPE_LED
  PORTRAIT_LED
}

enum HomeGalleryMosaicVariant {
  BALANCED_CLASSIC
  BALANCED_RHYTHM
  BALANCED_STACK
  LANDSCAPE_HERO_LEFT
  LANDSCAPE_PANORAMA_TOP
  LANDSCAPE_WIDE_DUO
  PORTRAIT_COLUMNS
  PORTRAIT_EDITORIAL
  PORTRAIT_FEATURE_PAIR
}

enum HomeGalleryRotationTrigger {
  AUTOMATIC
  MANUAL
}

enum HomeGallerySlotOrientation {
  LANDSCAPE
  PORTRAIT
  SQUARE
}

enum CalendarBlockSource {
  BOOKING_CONFIRMED
  BOOKING_HOLD
  MANUAL_BLOCK
}

enum CalendarBlockStatus {
  ACTIVE
  RELEASED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  EXPIRED
  EXITED
  PAYMENT_FAILED
  CANCELLED
}

enum BookingAccessTokenStatus {
  ACTIVE
  EXPIRED
  REVOKED
}

enum BookingSource {
  PUBLIC_CHECKOUT
  BACKPANEL
}

enum PaymentRecordStatus {
  PENDING
  SUCCEEDED
  MANUALLY_PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProviderEventStatus {
  FAILED
  IGNORED
  PROCESSED
}

enum CouponStatus {
  ACTIVE
  DRAFT
  EXPIRED
  PAUSED
}

enum CouponVersionStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum CouponDiscountType {
  FIXED_AMOUNT
  PERCENTAGE
}

enum CouponRedemptionStatus {
  CONFIRMED
  REFUNDED
  RELEASED
  RESERVED
  VOIDED
}

enum CouponEventType {
  COUPON_CONFIRMED
  COUPON_CREATED
  COUPON_RELEASED
  COUPON_RESERVED
  COUPON_VERSION_CREATED
}

enum CouponActorType {
  ADMIN
  CUSTOMER
  SYSTEM
}

enum CancellationPolicyStatus {
  ACTIVE
  ARCHIVED
}

enum CancellationPolicyVersionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum CancellationDepositOutcome {
  FULL_REFUND
  MANUAL_REVIEW
  NO_REFUND
  PARTIAL_REFUND
}

enum OutboxMessageStatus {
  PENDING
  PUBLISHED
  FAILED
}

enum BookingNotificationConsentSource {
  CHECKOUT
  BACKPANEL
  BUYER_ACCESS
}

enum BookingNotificationConsentStatus {
  GRANTED
  NOT_ASKED
  REVOKED
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
}

enum NotificationRecipientType {
  BUYER
}

enum NotificationRuleSendMode {
  AUTOMATIC
  MANUAL_REVIEW
}

enum NotificationRuleStatus {
  ACTIVE
  ARCHIVED
}

enum NotificationRuleLocaleStrategy {
  BOOKING_PREFERRED_LOCALE
}

enum NotificationRuleMissingTranslationBehavior {
  DO_NOT_SEND
}

enum NotificationTemplateStatus {
  ACTIVE
  ARCHIVED
  DRAFT
  READY
}

enum NotificationTemplateTranslationStatus {
  ARCHIVED
  DRAFT
  PUBLISHED
  READY
}

enum NotificationDeliveryStatus {
  CANCELLED
  DELIVERED
  FAILED
  MANUAL_REVIEW
  PENDING
  SENT
}

enum PushSubscriptionPlatform {
  ANDROID
  DESKTOP
  IOS
  UNKNOWN
}

enum PushSubscriptionPermission {
  DEFAULT
  DENIED
  GRANTED
}

enum PushSubscriptionStatus {
  ACTIVE
  DISABLED
}

enum PushDeliveryAttemptStatus {
  FAILED
  SENT
}

model Experience {
  id                        String                       @id
  internalName              String                       @map("internal_name")
  type                      String
  status                    ExperienceStatus
  displayOrder              Int                          @default(1) @map("display_order")
  basePriceAmountMinor      Int                          @map("base_price_amount_minor")
  basePriceCurrency         String                       @map("base_price_currency")
  depositAmountMinor        Int                          @map("deposit_amount_minor")
  depositCurrency           String                       @map("deposit_currency")
  durationMinutes           Int                          @map("duration_minutes")
  capacity                  Int
  departurePort             String                       @default("Port Olimpic, Barcelona") @map("departure_port")
  includedItems             String                       @map("included_items")
  internalNotes             String                       @default("") @map("internal_notes")
  bufferMinutes             Int                          @default(30) @map("buffer_minutes")
  minimumAdvanceMinutes     Int                          @default(60) @map("minimum_advance_minutes")
  maximumAdvanceMonths      Int                          @default(6) @map("maximum_advance_months")
  allowsManualScheduling    Boolean                      @default(true) @map("allows_manual_scheduling")
  primaryMediaAssetId       String?                      @map("primary_media_asset_id")
  primaryMediaStatus        ExperienceMediaStatus        @default(MISSING) @map("primary_media_status")
  slotPolicyMode            SlotPolicyMode               @map("slot_policy_mode")
  slotPolicyTimezone        String                       @map("slot_policy_timezone")
  slotOperatingStartMinutes Int?                         @map("slot_operating_start_minutes")
  slotOperatingEndMinutes   Int?                         @map("slot_operating_end_minutes")
  slotGranularityMinutes    Int?                         @map("slot_granularity_minutes")
  cancellationPolicyId      String?                      @map("cancellation_policy_id")
  cancellationPolicy        CancellationPolicy?          @relation(fields: [cancellationPolicyId], references: [id], onDelete: SetNull)
  fixedSlots                ExperienceFixedSlot[]
  extraRules                ExperienceExtraRule[]
  localizedContents         LocalizedExperienceContent[]
  createdAt                 DateTime                     @default(now()) @map("created_at")
  updatedAt                 DateTime                     @updatedAt @map("updated_at")

  @@index([status], map: "experiences_status_idx")
  @@index([displayOrder], map: "experiences_display_order_idx")
  @@index([primaryMediaAssetId], map: "experiences_primary_media_asset_id_idx")
  @@index([cancellationPolicyId], map: "experiences_cancellation_policy_id_idx")
  @@map("experiences")
}

model ExperienceFixedSlot {
  id           String     @id
  experienceId String     @map("experience_id")
  slotKey      String     @map("slot_key")
  label        String
  enabled      Boolean
  startMinutes Int        @map("start_minutes")
  endMinutes   Int        @map("end_minutes")
  position     Int
  experience   Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([experienceId, slotKey], map: "experience_fixed_slots_experience_id_slot_key_key")
  @@index([experienceId], map: "experience_fixed_slots_experience_id_idx")
  @@map("experience_fixed_slots")
}

model Extra {
  id                   String                @id
  name                 String
  status               ExtraStatus
  priceAmountMinor     Int                   @map("price_amount_minor")
  priceCurrency        String                @map("price_currency")
  defaultNoticeMinutes Int                   @map("default_notice_minutes")
  primaryMediaAssetId  String?               @map("primary_media_asset_id")
  experienceRules      ExperienceExtraRule[]
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")

  @@index([status], map: "extras_status_idx")
  @@index([primaryMediaAssetId], map: "extras_primary_media_asset_id_idx")
  @@map("extras")
}

model ExperienceExtraRule {
  id                       String     @id
  experienceId             String     @map("experience_id")
  extraId                  String     @map("extra_id")
  enabled                  Boolean
  limitPerBooking          Int        @map("limit_per_booking")
  noticeMinutes            Int        @map("notice_minutes")
  priceOverrideAmountMinor Int?       @map("price_override_amount_minor")
  priceOverrideCurrency    String?    @map("price_override_currency")
  capacityReduction        Int        @map("capacity_reduction")
  slotKey                  String?    @map("slot_key")
  experience               Experience @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  extra                    Extra      @relation(fields: [extraId], references: [id], onDelete: Restrict)
  createdAt                DateTime   @default(now()) @map("created_at")
  updatedAt                DateTime   @updatedAt @map("updated_at")

  @@unique([experienceId, extraId, slotKey], map: "experience_extra_rules_experience_id_extra_id_slot_key_key")
  @@index([experienceId], map: "experience_extra_rules_experience_id_idx")
  @@index([extraId], map: "experience_extra_rules_extra_id_idx")
  @@index([slotKey], map: "experience_extra_rules_slot_key_idx")
  @@map("experience_extra_rules")
}

model LocalizedExperienceContent {
  id                String                   @id
  experienceId      String                   @map("experience_id")
  locale            String
  slug              String
  status            LocalizedContentStatus
  publicPageEnabled Boolean                  @map("public_page_enabled")
  indexingPolicy    IndexingPolicy           @map("indexing_policy")
  title             String
  h1                String
  summary           String                   @default("")
  mainContent       String                   @map("main_content")
  includedText      String                   @default("") @map("included_text")
  bringText         String                   @default("") @map("bring_text")
  visibleTerms      String                   @default("") @map("visible_terms")
  seoTitle          String                   @map("seo_title")
  seoDescription    String                   @map("seo_description")
  geoSummary        String                   @map("geo_summary")
  keyFacts          String                   @default("") @map("key_facts")
  imageAltText      String                   @default("") @map("image_alt_text")
  sourceVersion     Int                      @default(1) @map("source_version")
  publishedAt       DateTime?                @map("published_at")
  experience        Experience               @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  faqItems          LocalizedExperienceFaq[]
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  @@unique([experienceId, locale], map: "localized_experience_contents_experience_id_locale_key")
  @@unique([locale, slug], map: "localized_experience_contents_locale_slug_key")
  @@index([experienceId], map: "localized_experience_contents_experience_id_idx")
  @@index([locale, status], map: "localized_experience_contents_locale_status_idx")
  @@index([locale, slug], map: "localized_experience_contents_slug_idx")
  @@map("localized_experience_contents")
}

model LocalizedExperienceFaq {
  id                 String                     @id
  localizedContentId String                     @map("localized_content_id")
  question           String
  answer             String
  position           Int
  localizedContent   LocalizedExperienceContent @relation(fields: [localizedContentId], references: [id], onDelete: Cascade)
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  @@unique([localizedContentId, position], map: "localized_experience_faqs_content_id_position_key")
  @@index([localizedContentId], map: "localized_experience_faqs_content_id_idx")
  @@map("localized_experience_faqs")
}

model MediaAsset {
  id                  String                       @id
  title               String
  collection          MediaAssetCollection
  status              MediaAssetStatus
  originalPrivatePath String                       @map("original_private_path")
  originalFilename    String                       @map("original_filename")
  mimeType            String                       @map("mime_type")
  originalWidth       Int                          @map("original_width")
  originalHeight      Int                          @map("original_height")
  originalSizeBytes   Int                          @map("original_size_bytes")
  originalContentHash String                       @map("original_content_hash")
  failureReason       String?                      @map("failure_reason")
  variants            MediaAssetVariant[]
  altTexts            MediaAltText[]
  processingJobs      MediaProcessingJob[]
  homeGallerySlots    HomeGalleryCompositionSlot[]
  createdAt           DateTime                     @default(now()) @map("created_at")
  updatedAt           DateTime                     @updatedAt @map("updated_at")

  @@index([status], map: "media_assets_status_idx")
  @@index([collection], map: "media_assets_collection_idx")
  @@index([originalContentHash], map: "media_assets_original_content_hash_idx")
  @@index([updatedAt], map: "media_assets_updated_at_idx")
  @@map("media_assets")
}

model MediaAssetVariant {
  id           String     @id
  mediaAssetId String     @map("media_asset_id")
  variantKey   String     @map("variant_key")
  publicPath   String     @map("public_path")
  format       String
  width        Int
  height       Int
  sizeBytes    Int        @map("size_bytes")
  contentHash  String     @map("content_hash")
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([mediaAssetId, variantKey], map: "media_asset_variants_asset_id_variant_key_key")
  @@unique([publicPath], map: "media_asset_variants_public_path_key")
  @@index([mediaAssetId], map: "media_asset_variants_media_asset_id_idx")
  @@map("media_asset_variants")
}

model MediaAltText {
  id           String     @id
  mediaAssetId String     @map("media_asset_id")
  locale       String
  altText      String     @map("alt_text")
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  @@unique([mediaAssetId, locale], map: "media_alt_texts_media_asset_id_locale_key")
  @@index([mediaAssetId], map: "media_alt_texts_media_asset_id_idx")
  @@map("media_alt_texts")
}

model MediaProcessingJob {
  id           String                   @id
  mediaAssetId String                   @map("media_asset_id")
  status       MediaProcessingJobStatus
  attempts     Int                      @default(0)
  startedAt    DateTime?                @map("started_at")
  completedAt  DateTime?                @map("completed_at")
  lastError    String?                  @map("last_error")
  mediaAsset   MediaAsset               @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  createdAt    DateTime                 @default(now()) @map("created_at")
  updatedAt    DateTime                 @updatedAt @map("updated_at")

  @@index([status, createdAt], map: "media_processing_jobs_pick_idx")
  @@index([mediaAssetId], map: "media_processing_jobs_media_asset_id_idx")
  @@map("media_processing_jobs")
}

model HomeGalleryComposition {
  id            String                       @id
  layout        HomeGalleryLayout
  mosaicVariant HomeGalleryMosaicVariant     @default(BALANCED_CLASSIC) @map("mosaic_variant")
  trigger       HomeGalleryRotationTrigger
  seed          String
  publishedAt   DateTime                     @map("published_at") @db.Timestamptz(3)
  expiresAt     DateTime                     @map("expires_at") @db.Timestamptz(3)
  slots         HomeGalleryCompositionSlot[]
  createdAt     DateTime                     @default(now()) @map("created_at")

  @@index([publishedAt], map: "home_gallery_compositions_published_at_idx")
  @@index([expiresAt], map: "home_gallery_compositions_expires_at_idx")
  @@map("home_gallery_compositions")
}

model HomeGalleryCompositionSlot {
  id            String                     @id
  compositionId String                     @map("composition_id")
  mediaAssetId  String                     @map("media_asset_id")
  slotKey       String                     @map("slot_key")
  position      Int
  orientation   HomeGallerySlotOrientation
  composition   HomeGalleryComposition     @relation(fields: [compositionId], references: [id], onDelete: Cascade)
  mediaAsset    MediaAsset                 @relation(fields: [mediaAssetId], references: [id], onDelete: Restrict)
  createdAt     DateTime                   @default(now()) @map("created_at")

  @@unique([compositionId, position], map: "home_gallery_slots_composition_id_position_key")
  @@unique([compositionId, slotKey], map: "home_gallery_slots_composition_id_slot_key_key")
  @@index([compositionId], map: "home_gallery_slots_composition_id_idx")
  @@index([mediaAssetId], map: "home_gallery_slots_media_asset_id_idx")
  @@map("home_gallery_composition_slots")
}

model CalendarBlock {
  id                  String              @id
  source              CalendarBlockSource
  status              CalendarBlockStatus
  bookingId           String?             @map("booking_id")
  experienceId        String?             @map("experience_id")
  localDate           DateTime            @map("local_date") @db.Date
  visibleStartMinutes Int                 @map("visible_start_minutes")
  visibleEndMinutes   Int                 @map("visible_end_minutes")
  protectedStartAt    DateTime            @map("protected_start_at") @db.Timestamptz(3)
  protectedEndAt      DateTime            @map("protected_end_at") @db.Timestamptz(3)
  timeZone            String              @map("timezone")
  expiresAt           DateTime?           @map("expires_at") @db.Timestamptz(3)
  reason              String
  createdByUserId     String              @map("created_by_user_id")
  createdAt           DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@index([localDate], map: "calendar_blocks_local_date_idx")
  @@index([bookingId], map: "calendar_blocks_booking_id_idx")
  @@index([experienceId], map: "calendar_blocks_experience_id_idx")
  @@index([protectedStartAt, protectedEndAt], map: "calendar_blocks_protected_range_idx")
  @@index([status, source], map: "calendar_blocks_status_source_idx")
  @@map("calendar_blocks")
}

model Booking {
  id                          String                         @id
  reference                   String                         @unique
  status                      BookingStatus
  source                      BookingSource
  experienceId                String                         @map("experience_id")
  experienceNameSnapshot      String                         @map("experience_name_snapshot")
  calendarBlockId             String                         @map("calendar_block_id")
  paymentRecordId             String                         @map("payment_record_id")
  guestCount                  Int                            @map("guest_count")
  customerName                String                         @map("customer_name")
  customerEmail               String                         @map("customer_email")
  customerPhone               String?                        @map("customer_phone")
  customerLocale              String                         @map("customer_locale")
  customerNotes               String                         @default("") @map("customer_notes")
  selectedLocalDate           DateTime                       @map("selected_local_date") @db.Date
  selectedStartMinutes        Int                            @map("selected_start_minutes")
  selectedEndMinutes          Int                            @map("selected_end_minutes")
  selectedSlotKey             String?                        @map("selected_slot_key")
  timeZone                    String                         @map("timezone")
  subtotalAmountMinor         Int                            @default(0) @map("subtotal_amount_minor")
  subtotalCurrency            String                         @default("EUR") @map("subtotal_currency")
  discountAmountMinor         Int                            @default(0) @map("discount_amount_minor")
  discountCurrency            String                         @default("EUR") @map("discount_currency")
  couponSnapshot              Json?                          @map("coupon_snapshot")
  totalAmountMinor            Int                            @map("total_amount_minor")
  totalCurrency               String                         @map("total_currency")
  depositAmountMinor          Int                            @map("deposit_amount_minor")
  depositCurrency             String                         @map("deposit_currency")
  cashRemainingAmountMinor    Int                            @map("cash_remaining_amount_minor")
  cashRemainingCurrency       String                         @map("cash_remaining_currency")
  priceCapturedAt             DateTime                       @map("price_captured_at") @db.Timestamptz(3)
  cancellationPolicyVersionId String?                        @map("cancellation_policy_version_id")
  cancellationPolicySnapshot  Json?                          @map("cancellation_policy_snapshot")
  holdExpiresAt               DateTime?                      @map("hold_expires_at") @db.Timestamptz(3)
  checkoutLastSeenAt          DateTime?                      @map("checkout_last_seen_at") @db.Timestamptz(3)
  confirmedAt                 DateTime?                      @map("confirmed_at") @db.Timestamptz(3)
  operationsSeenAt            DateTime?                      @map("operations_seen_at") @db.Timestamptz(3)
  cancelledAt                 DateTime?                      @map("cancelled_at") @db.Timestamptz(3)
  internalNotes               String                         @default("") @map("internal_notes")
  externalCalendarEventId     String?                        @unique(map: "bookings_external_calendar_event_id_key") @map("external_calendar_event_id")
  externalCalendarSyncedAt    DateTime?                      @map("external_calendar_synced_at") @db.Timestamptz(3)
  externalCalendarSyncError   String?                        @map("external_calendar_sync_error")
  createdByUserId             String?                        @map("created_by_user_id")
  createdAt                   DateTime                       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                   DateTime                       @updatedAt @map("updated_at") @db.Timestamptz(3)
  extras                      BookingExtra[]
  accessTokens                BookingAccessToken[]
  notificationDeliveries      NotificationDelivery[]
  notificationPreference      BookingNotificationPreference?
  paymentRecords              PaymentRecord[]
  couponRedemptions           CouponRedemption[]

  @@index([status], map: "bookings_status_idx")
  @@index([status, operationsSeenAt], map: "bookings_operations_seen_idx")
  @@index([status, holdExpiresAt, checkoutLastSeenAt], map: "bookings_payment_hold_expiration_idx")
  @@index([experienceId], map: "bookings_experience_id_idx")
  @@index([cancellationPolicyVersionId], map: "bookings_cancellation_policy_version_id_idx")
  @@index([customerEmail], map: "bookings_customer_email_idx")
  @@index([selectedLocalDate], map: "bookings_selected_date_idx")
  @@map("bookings")
}

model Coupon {
  id             String             @id
  codeNormalized String             @unique @map("code_normalized")
  displayCode    String             @map("display_code")
  name           String
  campaignName   String             @default("") @map("campaign_name")
  status         CouponStatus
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @map("updated_at") @db.Timestamptz(3)
  versions       CouponVersion[]
  redemptions    CouponRedemption[]
  events         CouponEvent[]

  @@index([status], map: "coupons_status_idx")
  @@map("coupons")
}

model CouponVersion {
  id                    String              @id
  couponId              String              @map("coupon_id")
  versionNumber         Int                 @map("version_number")
  status                CouponVersionStatus
  discountType          CouponDiscountType  @map("discount_type")
  discountAmountMinor   Int?                @map("discount_amount_minor")
  discountPercentageBps Int?                @map("discount_percentage_bps")
  currency              String
  validFrom             DateTime            @map("valid_from") @db.Timestamptz(3)
  validUntil            DateTime?           @map("valid_until") @db.Timestamptz(3)
  maxTotalRedemptions   Int?                @map("max_total_redemptions")
  experienceIds         String[]            @default([]) @map("experience_ids")
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  coupon                Coupon              @relation(fields: [couponId], references: [id], onDelete: Cascade)
  redemptions           CouponRedemption[]
  events                CouponEvent[]

  @@unique([couponId, versionNumber], map: "coupon_versions_coupon_id_version_number_key")
  @@index([couponId, status], map: "coupon_versions_coupon_status_idx")
  @@index([validFrom, validUntil], map: "coupon_versions_valid_range_idx")
  @@map("coupon_versions")
}

model CouponRedemption {
  id                               String                 @id
  couponId                         String                 @map("coupon_id")
  couponVersionId                  String                 @map("coupon_version_id")
  bookingId                        String                 @unique @map("booking_id")
  paymentRecordId                  String?                @map("payment_record_id")
  customerEmailNormalized          String                 @map("customer_email_normalized")
  status                           CouponRedemptionStatus
  discountAmountMinor              Int                    @map("discount_amount_minor")
  currency                         String
  originalTotalAmountMinor         Int                    @map("original_total_amount_minor")
  finalTotalAmountMinor            Int                    @map("final_total_amount_minor")
  originalDepositAmountMinor       Int                    @map("original_deposit_amount_minor")
  finalDepositAmountMinor          Int                    @map("final_deposit_amount_minor")
  originalCashRemainingAmountMinor Int                    @map("original_cash_remaining_amount_minor")
  finalCashRemainingAmountMinor    Int                    @map("final_cash_remaining_amount_minor")
  couponSnapshot                   Json                   @map("coupon_snapshot")
  reservedAt                       DateTime               @map("reserved_at") @db.Timestamptz(3)
  confirmedAt                      DateTime?              @map("confirmed_at") @db.Timestamptz(3)
  releasedAt                       DateTime?              @map("released_at") @db.Timestamptz(3)
  voidedAt                         DateTime?              @map("voided_at") @db.Timestamptz(3)
