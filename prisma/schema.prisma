  @@index([bookingId], map: "notification_deliveries_booking_id_idx")
  @@index([channel, status], map: "notification_deliveries_channel_status_idx")
  @@index([outboxMessageId, ruleId], map: "notification_deliveries_outbox_rule_idx")
  @@map("notification_deliveries")
}

