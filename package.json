{
  "name": "jimboats-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "@swc/core",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS=--max-old-space-size=4096 next build",
    "rules:check": "node scripts/rules/check.mjs",
    "start": "next start",
    "lint": "eslint . --ignore-pattern .worker/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ui": "vitest run",
    "test:visual": "playwright test tests/visual.spec.ts",
    "test:responsive": "playwright test tests/responsive.spec.ts",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "dev:docker": "docker compose up --build app media-worker home-gallery-worker booking-calendar-sync-worker booking-hold-expiration-worker notification-worker caddy",
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "db:generate": "DATABASE_URL=${DATABASE_URL:-postgresql://jimboats:jimboats@db:5432/jimboats?schema=public} prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:docker": "docker compose up --wait -d db && docker compose run --rm app sh -lc \"CI=true pnpm install --frozen-lockfile --store-dir /pnpm/store && pnpm db:deploy\"",
    "db:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "booking-calendar-sync:worker:build": "esbuild src/interface/worker/bookingCalendarSyncWorkerCli.ts --bundle --platform=node --target=node24 --format=cjs --packages=external --outfile=.worker/booking-calendar-sync-worker.cjs",
    "booking-calendar-sync:worker": "pnpm booking-calendar-sync:worker:build && node .worker/booking-calendar-sync-worker.cjs",
    "booking-hold-expiration:worker:build": "esbuild src/interface/worker/bookingHoldExpirationWorkerCli.ts --bundle --platform=node --target=node24 --format=cjs --packages=external --outfile=.worker/booking-hold-expiration-worker.cjs",
    "booking-hold-expiration:worker": "pnpm booking-hold-expiration:worker:build && node .worker/booking-hold-expiration-worker.cjs",
    "home-gallery:worker:build": "esbuild src/interface/worker/homeGalleryWorkerCli.ts --bundle --platform=node --target=node24 --format=cjs --packages=external --outfile=.worker/home-gallery-worker.cjs",
    "home-gallery:worker": "pnpm home-gallery:worker:build && node .worker/home-gallery-worker.cjs",
    "media:prepare": "node scripts/media/prepare.mjs",
    "media:worker:build": "esbuild src/interface/worker/mediaWorkerCli.ts --bundle --platform=node --target=node24 --format=cjs --packages=external --outfile=.worker/media-worker.cjs",
    "media:worker": "pnpm media:worker:build && node .worker/media-worker.cjs",
    "notifications:worker:build": "esbuild src/interface/worker/notificationWorkerCli.ts --bundle --platform=node --target=node24 --format=cjs --packages=external --outfile=.worker/notification-worker.cjs",
    "notifications:worker": "pnpm notifications:worker:build && node .worker/notification-worker.cjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@statsig/react-bindings": "^3.33.2",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.7.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "googleapis": "^173.0.0",
    "lucide-react": "1.17.0",
    "next": "16.2.6",
    "pg": "8.16.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "sharp": "0.33.5",
    "stripe": "^22.2.0",
    "tailwind-merge": "3.6.0",
    "web-push": "^3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@playwright/test": "1.60.0",
    "@storybook/addon-a11y": "10.4.1",
    "@storybook/nextjs-vite": "10.4.1",
    "@storybook/test-runner": "0.24.4",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "^3.6.4",
    "@vitejs/plugin-react": "6.0.2",
    "esbuild": "0.27.7",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "jsdom": "29.1.1",
    "postcss": "8.5.15",
    "prettier": "3.8.3",
    "prisma": "7.8.0",
    "storybook": "10.4.1",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
